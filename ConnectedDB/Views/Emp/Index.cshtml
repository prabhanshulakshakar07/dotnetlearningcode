@model IEnumerable<ConnectedDB.Models.Emp>

<div>
    <a href="/Emp/Create">Create New Employee</a>
</div>
<div class="container table-responsive">
    <div class="row p-1">
        <div class="col-md-8">
            <table class="table table-bordered">
                <thead>
                    <tr>
                        <th>
                            @Html.DisplayNameFor(model => model.Id)
                        </th>
                        <th>
                            @Html.DisplayNameFor(model => model.Name)
                        </th>
                        <th>
                            @Html.DisplayNameFor(model => model.Address)
                        </th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var emp in Model)
                    {
                        <tr>
                            <td>@emp.Id</td>
                            <td>@emp.Name</td>
                            <td>@emp.Address</td>

                            <td>
                                <a href="/Emp/Edit/@emp.Id" class="text-primary">Edit</a>
                            </td>

                            <td>
                                <a href="/Emp/Delete/@emp.Id" class="text-danger">Delete</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>